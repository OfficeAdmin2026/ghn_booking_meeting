NODE_ENV=production
PORT=5001

# === DATABASE ===
# Option 1: single connection string (Supabase / Render / Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: individual params (local dev only)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ghn_meeting_room_booking
# DB_USER=postgres
# DB_PASSWORD=

# === JWT ===
JWT_SECRET=replace_with_random_64_char_string
JWT_EXPIRES_IN=7d

# === GOOGLE OAUTH (Sign in with Google) ===
# OAuth Client ID from Google Cloud Console — must match frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# === CORS ===
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.netlify.app

# === BUSINESS RULES ===
COMPANY_DOMAIN=ghn.vn
MAX_BOOKING_DURATION_HOURS=4
BOOKING_WINDOW_DAYS=30
